# Database
DB_URL=jdbc:postgresql://localhost:5432/nexusai
DB_USER=nexusai
DB_PASSWORD=nexusai

# JWT — generate a strong secret for production (min 32 chars)
JWT_SECRET=change-this-to-a-strong-random-secret-at-least-32-chars
JWT_EXPIRATION=86400000

# AI Provider — use 'ollama' for local (free) or 'openai' for cloud
AI_PROVIDER=ollama

# Ollama (only needed when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# OpenAI (only needed when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Server
PORT=8080
