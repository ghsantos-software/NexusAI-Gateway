{
  "info": {
    "name": "NexusAI Gateway",
    "description": "Corporate AI Gateway — DLP, RAG, rate limiting, audit",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('Token saved:', json.data.token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Acme Corp\",\n  \"email\": \"john@acme.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Creates a new user and tenant. Returns a JWT token. The test script auto-saves the token to the collection variable."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    console.log('Token saved:', json.data.token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@acme.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get current user",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "me"]
            }
          },
          "response": []
        },
        {
          "name": "List tenant users (ADMIN)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "AI Gateway",
      "item": [
        {
          "name": "Chat - simple message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"What is a REST API? Explain in 2 sentences.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/ai/chat",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ai", "chat"]
            }
          },
          "response": []
        },
        {
          "name": "Chat - DLP masking demo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"My CPF is 123.456.789-09, email is user@example.com and phone is (11) 98765-4321. Can I get a refund?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/ai/chat",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ai", "chat"]
            },
            "description": "The CPF, email, and phone will be automatically masked before reaching the LLM. Check dlpApplied: true in the response."
          },
          "response": []
        },
        {
          "name": "Chat - with RAG context",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"What are the refund policies?\",\n  \"useRag\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/ai/chat",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ai", "chat"]
            },
            "description": "Upload a document first via the RAG folder, then ask a question about it here."
          },
          "response": []
        },
        {
          "name": "Chat - skip RAG",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Summarize the latest AI trends in 3 bullet points.\",\n  \"useRag\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/ai/chat",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ai", "chat"]
            }
          },
          "response": []
        },
        {
          "name": "Chat - custom system prompt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"What can you help me with?\",\n  \"systemPrompt\": \"You are a helpful customer support agent for a software company. Always be friendly and offer concrete next steps.\",\n  \"useRag\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/ai/chat",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ai", "chat"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "RAG",
      "item": [
        {
          "name": "Upload TXT document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Select a .txt or .pdf file"
                },
                {
                  "key": "documentName",
                  "value": "company-policies",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/rag/documents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rag", "documents"]
            },
            "description": "Upload a TXT or PDF document. The file is chunked and embeddings are generated and stored in pgvector. Requires OPENAI_API_KEY for embeddings."
          },
          "response": []
        },
        {
          "name": "List documents",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rag/documents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rag", "documents"]
            }
          },
          "response": []
        },
        {
          "name": "Delete document",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/rag/documents/company-policies",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "rag", "documents", "company-policies"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "List audit logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/audit?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "audit"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Returns a paginated list of audit log entries. ADMIN role required. Raw prompts are never stored — only SHA-256 hash."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            },
            "description": "Returns application health including Ollama connectivity status."
          },
          "response": []
        },
        {
          "name": "Prometheus metrics",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/actuator/prometheus",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "prometheus"]
            },
            "description": "Prometheus scrape endpoint. Look for nexusai.* metrics."
          },
          "response": []
        }
      ]
    }
  ]
}
